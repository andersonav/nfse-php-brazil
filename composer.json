{
  "name": "alves/nfse-php-brazil",
  "description": "Pacote para emissao de NFS-e para municipios brasileiros usando componentes NFePHP (https://github.com/nfephp-org)",
  "keywords": [
    "nfse-php-brazil",
    "nfse",
    "mei"
  ],
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Alves\\NfseBrasil\\": "src/"
    },
    "files": [
      "Helpers.php"
    ]
  },
  "authors": [
    {
      "name": "Anderson Alves",
      "email": "andersonalves.dev@gmail.com"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": "^8.1",
    "symfony/var-dumper": "^7.1|^6.4",
    "setasign/fpdf": "^1.8",
    "tecnickcom/tcpdf": "^6.7",
    "nfephp-org/sped-common": "^5.1",
    "ext-dom": "*",
    "ext-curl": "*",
    "ext-zlib": "*",
    "ext-openssl": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "config": {
    "optimize-autoloader": true
  },
  "scripts": {
    "municipio:info": "php bin/municipio-info.php",
    "test": "phpunit --colors=always",
    "test:municipios": "phpunit --testsuite municipios --colors=always",
    "test:integration": "phpunit --testsuite integration --colors=always",
    "test:real": "NFSE_REAL_TESTS=1 phpunit --testsuite integration --colors=always",
    "docker:up": "docker compose up -d --build",
    "docker:shell": "docker compose exec app bash"
  },
  "prefer-stable": true
}
